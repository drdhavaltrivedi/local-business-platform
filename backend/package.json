{
  "name": "@local-business-platform/backend",
  "version": "1.0.0",
  "description": "Backend API for Local Business Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "mkdir -p dist/migrations && cp src/migrations/*.sql dist/migrations/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "migrate": "node dist/migrations/run.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "stripe": "^14.7.0",
    "zod": "^3.22.4",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "geolib": "^3.3.4",
    "csv-parse": "^5.5.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.10.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}

